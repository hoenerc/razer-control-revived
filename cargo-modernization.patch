+[profile.release]
+# Same philosophy as the system kernel build: ThinLTO, single codegen unit.
+# Measurably smaller/tighter binaries at the cost of clean-build time only.
+lto = "thin"
+codegen-units = 1
+strip = "symbols"
+
 [dependencies]
-dbus = "0.9.7"
+dbus = "0.9.12"
 serde = { version = "1.0", features = ["derive"] }
 serde_json = "1.0"
-signal-hook = "0.3.17"
-rand = "0.8.5"
-bincode = "1.3.3"
+# 0.4 is a semver-major bump (small API surface here: Signals::new + forever
+# in the shutdown task) — staged for the next major-update pass.
+signal-hook = "0.3.18"
+# PINNED BY DESIGN — do not migrate to bincode >= 2 casually. bincode encodes
+# two wire formats here: the 91-byte RazerPacket HID feature report (byte-exact
+# EC protocol framing: field order, little-endian u16, raw fixed arrays via
+# serde-big-array) and the daemon IPC. bincode 2+/3+ default to variable-length
+# integer encoding; a naive migration would silently corrupt the EC protocol.
+# 1.3.3 is unmaintained but frozen-stable. Long-term hardening option: replace
+# bincode for RazerPacket with an explicit hand-rolled 91-byte encoder so the
+# EC wire layout depends on no serializer semantics at all.
+bincode = "=1.3.3"
 libc = "0.2"
-hidapi = { version = "2.4.1", default-features = false, features = ["linux-native"] }
+hidapi = { version = "2.6", default-features = false, features = ["linux-native"] }
 serde-big-array = "0.5.1"
-clap = { version = "4.4.13", features = ["derive"] }
+clap = { version = "4.6", features = ["derive"] }
+# The gtk-rs stack (gtk4 + libadwaita + glib) moves as a coordinated trio and
