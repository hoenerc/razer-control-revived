+# iterative compile-and-fix session against the GUI — staged separately, see
+# the dependency-modernization notes.
 gtk4 = { version = "0.9", features = ["v4_12"] }
 libadwaita = { version = "0.7", features = ["v1_5"] }
 glib = "0.20"
