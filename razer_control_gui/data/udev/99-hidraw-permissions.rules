# Razer Laptop Control (Blade 16 2025 personal fork) - hidraw access
# 2025 models only: Blade 14 2025 (02c5), Blade 16 2025 (02c6), Blade 18 2025 (02c7).
# Older models were dropped together with the legacy profile map; use the
# upstream forks for pre-2025 hardware.
KERNEL=="hidraw*", ATTRS{idProduct}=="02c5|02c6|02c7", ATTRS{idVendor}=="1532", MODE="0666", TAG+="uaccess"
